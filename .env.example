# Server
PORT=3000

# Music directory (for YouTube download feature)
MUSIC_DIR=/mnt/c/Music/Album
YT_DLP_COMMAND=yt-dlp

# MongoDB Atlas
# Obtain your connection string from: https://cloud.mongodb.com -> Clusters -> Connect
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=nas-dash
MONGO_LINKS_COLLECTION=links
